# ══════════════════════════════════════════════════════════════════
# Visual Recommendations Backend -- Environment Configuration
# ══════════════════════════════════════════════════════════════════
#
# Quick start:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your API keys below
#   3. Run:  docker-compose up --build
#
# ── LLM Providers ──────────────────────────────────────────────────
# Text/vision calls and image generation can use different providers.
TEXT_PROVIDER=openai
IMAGE_PROVIDER=gemini

# Google Gemini (required when IMAGE_PROVIDER=gemini or TEXT_PROVIDER=gemini)
GOOGLE_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# OpenAI (required when TEXT_PROVIDER=openai or IMAGE_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=gpt-image-1

# Anthropic Claude (optional -- used as fallback or for provider comparison)
ANTHROPIC_API_KEY=
CLAUDE_VISION_MODEL=claude-sonnet-4-20250514

# ── Database ───────────────────────────────────────────────────────
# Credentials for the PostgreSQL container. Change the password for production.
POSTGRES_USER=visrec
POSTGRES_PASSWORD=changeme

# ── Security ───────────────────────────────────────────────────────
# Comma-separated allowed origins for CORS, or * for all (dev only).
CORS_ORIGINS=*

# ── General ────────────────────────────────────────────────────────
MAX_RETRIES=3
IMAGE_SIZE=1024x1024
LOG_LEVEL=INFO
